# Rutherford MCP Server - environment configuration.
# Copy to `.env` and adjust. Rutherford never performs interactive logins; it only
# detects auth state. Set the API key for any CLI you authenticate by key, or run
# that CLI's one-time interactive login to establish a reusable session.
#
# `.env` is gitignored. Never commit real keys.

# --- Per-CLI authentication -------------------------------------------------
# Claude Code: an API key, or a `claude auth login` / `claude setup-token` session.
ANTHROPIC_API_KEY=

# Codex: an API key, or a `codex login` (ChatGPT plan) session.
OPENAI_API_KEY=
# CODEX_API_KEY=        # optional per-invocation override for Codex

# Kiro: requires Pro/Pro+/Power to mint a key, or a `kiro-cli login` session.
KIRO_API_KEY=

# OpenCode: bring-your-own-provider. Set whichever providers you use.
# ANTHROPIC_API_KEY / OPENAI_API_KEY above are reused; add others as needed.
# OPENROUTER_API_KEY=
# Ollama needs no key (auto-detected at http://localhost:11434).

# Goose: bring-your-own-provider. Select the provider/model and its key.
# GOOSE_PROVIDER=anthropic
# GOOSE_MODEL=claude-sonnet-4-6
# GOOSE_DISABLE_KEYRING=true   # set in headless/CI environments without a keyring

# Antigravity (agy): authenticates via a Google account flow with no API-key env
# var; run `agy` once interactively to sign in.

# Cursor (cursor-agent): a `cursor-agent login` session, or an API key.
CURSOR_API_KEY=

# Qwen Code (qwen): a `qwen` OAuth session (default, no key), or an OpenAI-
# compatible key. Set OPENAI_API_KEY (reused above) with --auth-type openai, or:
# DASHSCOPE_API_KEY=

# --- Rutherford runtime tuning (all optional; defaults shown) ----------------
# RUTHERFORD_CONFIG=         # path to a config file, overriding discovery
# RUTHERFORD_MAX_DEPTH=3     # max delegation depth before a chain is refused
# RUTHERFORD_MAX_TARGETS=8   # max targets per consensus call
# RUTHERFORD_DEFAULT_TIMEOUT_S=300
# RUTHERFORD_DEFAULT_SAFETY=read_only
# RUTHERFORD_TRUSTED_WORKSPACES=   # os.pathsep-separated allowlist for write/yolo

# RUTHERFORD_DEPTH is set automatically by Rutherford on spawned children; do not
# set it yourself.
